# ─────────────────────────────────────────────────────────────────────────────
# ABA Shield — environment variable template
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and public anon key (safe to expose in the browser bundle).
# Supabase dashboard → Project Settings → API. Only the anon key belongs here —
# never the service_role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── DEMO MODE ────────────────────────────────────────────────────────────────
# true  → hardcoded demo drafts, no AI calls, zero cost (default for dev/demo)
# false → real Claude AI draft generation (requires ANTHROPIC_API_KEY below)
VITE_DEMO_MODE=true

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required only when VITE_DEMO_MODE=false.
# Server-side only — key is never exposed to the browser bundle.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── AssemblyAI Transcription ──────────────────────────────────────────────────
# Required for voice recording → transcript feature.
# https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# ── Dev flags ────────────────────────────────────────────────────────────────
# true  → mock transcript (instant, free)   false → real AssemblyAI call
DEV_MOCK_TRANSCRIPTION=true
MAX_TRANSCRIPTION_MINUTES=5
