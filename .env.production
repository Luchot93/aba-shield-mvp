# ─────────────────────────────────────────────────────────────────────────────
# ABA Shield — production build fallback values.
# This file IS committed to the repo (unlike .env.local).
#
# Real values are set as Environment Variables in the Vercel dashboard and take
# priority over these at build time (Vite gives pre-existing process.env vars
# priority over values loaded from .env files). These placeholders only exist
# so a production build never silently runs with `undefined` env vars.
#
# Never put ANTHROPIC_API_KEY or any other server-only secret in this file —
# only VITE_* vars belong here, since they get bundled into the client build.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-anon-key
VITE_DEMO_MODE=true
